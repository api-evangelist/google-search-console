{
  "@context": {
    "@version": 1.1,
    "gsc": "https://developers.google.com/webmaster-tools/schema/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "SearchConsoleSite": "gsc:SearchConsoleSite",
    "SearchAnalyticsQuery": "gsc:SearchAnalyticsQuery",
    "SearchAnalyticsRow": "gsc:SearchAnalyticsRow",
    "Sitemap": "gsc:Sitemap",
    "SitemapContent": "gsc:SitemapContent",
    "UrlInspectionRequest": "gsc:UrlInspectionRequest",
    "UrlInspectionResult": "gsc:UrlInspectionResult",
    "IndexStatusResult": "gsc:IndexStatusResult",
    "MobileUsabilityResult": "gsc:MobileUsabilityResult",
    "RichResultsResult": "gsc:RichResultsResult",
    "DimensionFilter": "gsc:DimensionFilter",
    "DimensionFilterGroup": "gsc:DimensionFilterGroup",

    "name": "schema:name",
    "description": "schema:description",
    "url": {"@id": "schema:url", "@type": "@id"},
    "dateCreated": "schema:dateCreated",
    "dateModified": "schema:dateModified",
    "identifier": "schema:identifier",

    "siteUrl": {"@id": "gsc:siteUrl", "@type": "@id"},
    "permissionLevel": "gsc:permissionLevel",

    "startDate": {"@id": "gsc:startDate", "@type": "xsd:date"},
    "endDate": {"@id": "gsc:endDate", "@type": "xsd:date"},
    "dimensions": "gsc:dimensions",
    "searchType": "gsc:searchType",
    "aggregationType": "gsc:aggregationType",
    "rowLimit": {"@id": "gsc:rowLimit", "@type": "xsd:integer"},
    "startRow": {"@id": "gsc:startRow", "@type": "xsd:integer"},
    "dataState": "gsc:dataState",

    "clicks": {"@id": "gsc:clicks", "@type": "xsd:double"},
    "impressions": {"@id": "gsc:impressions", "@type": "xsd:double"},
    "ctr": {"@id": "gsc:ctr", "@type": "xsd:double"},
    "position": {"@id": "gsc:position", "@type": "xsd:double"},
    "keys": "gsc:keys",
    "query": "gsc:query",
    "page": {"@id": "gsc:page", "@type": "@id"},
    "country": "gsc:country",
    "device": "gsc:device",
    "searchAppearance": "gsc:searchAppearance",

    "sitemapPath": {"@id": "gsc:sitemapPath", "@type": "@id"},
    "lastSubmitted": {"@id": "gsc:lastSubmitted", "@type": "xsd:dateTime"},
    "lastDownloaded": {"@id": "gsc:lastDownloaded", "@type": "xsd:dateTime"},
    "isPending": {"@id": "gsc:isPending", "@type": "xsd:boolean"},
    "isSitemapsIndex": {"@id": "gsc:isSitemapsIndex", "@type": "xsd:boolean"},
    "sitemapType": "gsc:sitemapType",
    "warnings": {"@id": "gsc:warnings", "@type": "xsd:integer"},
    "errors": {"@id": "gsc:errors", "@type": "xsd:integer"},
    "contentType": "gsc:contentType",
    "submitted": {"@id": "gsc:submitted", "@type": "xsd:long"},
    "indexed": {"@id": "gsc:indexed", "@type": "xsd:long"},

    "inspectionUrl": {"@id": "gsc:inspectionUrl", "@type": "@id"},
    "languageCode": "gsc:languageCode",
    "verdict": "gsc:verdict",
    "coverageState": "gsc:coverageState",
    "robotsTxtState": "gsc:robotsTxtState",
    "indexingState": "gsc:indexingState",
    "lastCrawlTime": {"@id": "gsc:lastCrawlTime", "@type": "xsd:dateTime"},
    "pageFetchState": "gsc:pageFetchState",
    "googleCanonical": {"@id": "gsc:googleCanonical", "@type": "@id"},
    "userCanonical": {"@id": "gsc:userCanonical", "@type": "@id"},
    "crawledAs": "gsc:crawledAs",
    "referringUrls": {"@id": "gsc:referringUrls", "@type": "@id"},

    "mobileUsabilityIssueType": "gsc:mobileUsabilityIssueType",
    "severity": "gsc:severity",
    "richResultType": "gsc:richResultType",
    "issueMessage": "gsc:issueMessage",

    "hasSitemap": {"@id": "gsc:hasSitemap", "@type": "@id"},
    "belongsToSite": {"@id": "gsc:belongsToSite", "@type": "@id"},
    "inspectedBy": {"@id": "gsc:inspectedBy", "@type": "@id"}
  }
}
